{
  "version": 2,
  "functions": {
    "server.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/create-payment-intent", "dest": "/server.js" },
    { "src": "/webhook", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
